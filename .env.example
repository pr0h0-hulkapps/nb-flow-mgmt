# netbird-flow-mgmt — environment for the patched NetBird management server.
# (The SIEM side — receiver, poller — is configured in the wazuh-siem repo.)
#
# Generate the shared HMAC secret once and use the SAME value here and as the
# wazuh-siem flow-receiver's NB_FLOW_HMAC_SECRET:
#   openssl rand -hex 32

# Address every agent can reach the flow-receiver at (mesh IP/DNS or public TLS).
NB_FLOW_URL=http://flow-receiver-host:9999

# Shared with the receiver (mint here, verify there). REQUIRED to activate flow.
NB_FLOW_HMAC_SECRET=replace-with-openssl-rand-hex-32

# Optional tuning (defaults shown).
NB_FLOW_ENABLED=true
NB_FLOW_INTERVAL=10s
NB_FLOW_TOKEN_TTL=1h
NB_FLOW_COUNTERS=true
NB_FLOW_DNS=false
NB_FLOW_EXIT_NODE=false
